# Upstash Redis (Vercel: Marketplace → Upstash, or upstash.com). Vercel often injects these names:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy names from older Vercel KV / imports still work in code:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Long random string. GET /api/export?token=… downloads .xlsx — keep this secret.
EXPORT_SECRET=change-me-to-a-long-random-value
