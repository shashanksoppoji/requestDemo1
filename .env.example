# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Service role = server-only (never put in client code or NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: defaults to form_submissions
# SUPABASE_FORM_TABLE=form_submissions

# Long random secret for GET /api/export?token=... (Excel download)
EXPORT_SECRET=
