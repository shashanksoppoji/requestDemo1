# ---------------------------------------------------------------------------
# Upstash Redis (required for POST /api/submit to save submissions)
# ---------------------------------------------------------------------------
# 1) Open https://console.upstash.com/ and sign in (GitHub OK).
# 2) Redis → Create database → pick a region (e.g. closest to you) → Create.
# 3) Open the database → scroll to "REST API".
# 4) Copy "UPSTASH_REDIS_REST_URL" and "UPSTASH_REDIS_REST_TOKEN" here.
# 5) Rename this file to .env.local (do not commit .env.local).
# 6) Restart: stop `npm run dev` and run it again.
#
# On Vercel: Project → Storage tab → Create → Upstash Redis → Connect to project,
# OR copy the same two vars from console.upstash.com into Project → Settings → Environment Variables.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alternate names some Vercel Redis integrations use (optional; kv.ts reads these too):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---------------------------------------------------------------------------
# Excel export secret (required for GET /api/export?token=...)
# ---------------------------------------------------------------------------
EXPORT_SECRET=
